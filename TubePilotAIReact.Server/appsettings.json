{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ComfyCloud": {
    "BaseUrl": "https://cloud.comfy.org",
    "ApiKey": "",
    "MaxConcurrentJobs": 1,
    "PollIntervalSeconds": 3,
    "JobTimeoutMinutes": 25,
    "TextToImageWorkflowPath": "Comfy/Workflows/text-to-image.json",
    "TextToImagePromptNode": { "NodeId": "6", "InputName": "text" },
    "ImageToVideoWorkflowPath": "Comfy/Workflows/image-to-video.json",
    "ImageToVideoImageNode": { "NodeId": "3", "InputName": "image" },
    "ImageToVideoPromptNode": { "NodeId": "8", "InputName": "text" }
  },
  "Storage": {
    "ProjectStorageRoot": "../ProjectStorage"
  }
}
